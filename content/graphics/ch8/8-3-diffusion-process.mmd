graph LR
    subgraph Forward["순방향 확산 과정 q(x_t|x_{t-1})"]
        direction LR
        X0["x₀<br/>원본"]
        X1["x₁"]
        DOTS1["..."]
        XT1["x_{t-1}"]
        XT["x_t"]
        DOTS2["..."]
        XTF["x_T<br/>순수 노이즈"]
    end

    X0 -->|"+ε"| X1
    X1 --> DOTS1
    DOTS1 --> XT1
    XT1 -->|"+ε"| XT
    XT --> DOTS2
    DOTS2 --> XTF

    subgraph Reverse["역방향 디노이징 과정 p_θ(x_{t-1}|x_t)"]
        direction RL
        R_XTF["x_T"]
        R_DOTS2["..."]
        R_XT["x_t"]
        R_XT1["x_{t-1}"]
        R_DOTS1["..."]
        R_X1["x₁"]
        R_X0["x₀<br/>생성"]
    end

    R_XTF -->|"-ε_θ"| R_DOTS2
    R_DOTS2 --> R_XT
    R_XT -->|"-ε_θ"| R_XT1
    R_XT1 --> R_DOTS1
    R_DOTS1 --> R_X1
    R_X1 --> R_X0
