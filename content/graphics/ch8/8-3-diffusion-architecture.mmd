graph TB
    subgraph Forward["순방향 과정 (Forward Process)"]
        X0["x₀<br/>원본 데이터"]
        X1["x₁"]
        XT["x_T<br/>~ N(0,I)"]
        NS["노이즈 스케줄<br/>β₁, β₂, ..., β_T"]
    end

    subgraph Reverse["역방향 과정 (Reverse Process)"]
        XT2["x_T<br/>순수 노이즈"]
        XTM["x_{t-1}"]
        X02["x₀<br/>생성 데이터"]
    end

    subgraph NoisePredictor["노이즈 예측기 ε_θ"]
        subgraph UNet["U-Net 구조"]
            ENC["Encoder<br/>(다운샘플링)"]
            MID["Middle Block<br/>(Self-Attention)"]
            DEC["Decoder<br/>(업샘플링)"]
            SKIP["Skip Connections"]
        end
        TE["시간 임베딩<br/>t → sin/cos"]
    end

    subgraph Loss["학습"]
        LOSS["L = E[||ε - ε_θ(x_t, t)||²]"]
    end

    X0 -->|"+√(1-α̅_t)·ε"| X1
    X1 -->|"..."| XT
    NS -.->|"스케줄 적용"| X1

    XT2 -->|"ε_θ 예측"| NoisePredictor
    NoisePredictor -->|"-노이즈"| XTM
    XTM -->|"반복 T회"| X02

    ENC --> MID --> DEC
    ENC -.-> SKIP -.-> DEC
    TE -->|"조건부 입력"| MID

    NoisePredictor --> LOSS
