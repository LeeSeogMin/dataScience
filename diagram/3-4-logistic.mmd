graph LR
    subgraph 입력[" "]
        X["<b>입력 특성</b><br/>x₁, x₂, ..."]
    end

    subgraph 선형[" "]
        Z["<b>선형 조합</b><br/>z = β₀ + Σβᵢxᵢ"]
    end

    subgraph 시그모이드[" "]
        S["<b>시그모이드</b><br/>σ(z) = 1/(1+e⁻ᶻ)"]
    end

    subgraph 출력[" "]
        P["<b>확률</b><br/>P(Y=1)"]
    end

    X --> Z --> S --> P

    P -->|"P ≥ 0.5"| Y1["예측: 1"]
    P -->|"P < 0.5"| Y0["예측: 0"]

    style X fill:#e3f2fd,stroke:#1976d2
    style Z fill:#fff3e0,stroke:#f57c00
    style S fill:#f3e5f5,stroke:#7b1fa2
    style P fill:#e8f5e9,stroke:#388e3c
    style Y1 fill:#c8e6c9,stroke:#388e3c
    style Y0 fill:#ffcdd2,stroke:#d32f2f
