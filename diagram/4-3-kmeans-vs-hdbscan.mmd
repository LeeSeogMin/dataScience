graph TB
    subgraph KM["K-Means"]
        direction TB
        KM1["● ● ●<br/>중심점 기반"]
        KM2["⊕ 중심점"]
        KM3["구형 경계"]
        KM4["모든 점 할당<br/>(노이즈도 포함)"]
        KM1 --> KM2 --> KM3 --> KM4
    end

    subgraph HD["HDBSCAN"]
        direction TB
        HD1["● ● ●<br/>밀도 기반"]
        HD2["고밀도 영역 탐색"]
        HD3["비구형 경계"]
        HD4["노이즈 분리<br/>(레이블 -1)"]
        HD1 --> HD2 --> HD3 --> HD4
    end

    KM ---|"vs"| HD

    style KM fill:#e3f2fd,stroke:#1976d2
    style HD fill:#f3e5f5,stroke:#7b1fa2
    style KM4 fill:#ffcdd2,stroke:#d32f2f
    style HD4 fill:#c8e6c9,stroke:#388e3c
