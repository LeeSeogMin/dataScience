graph LR
    subgraph INPUT["입력 텍스트"]
        T1["'배송이 빨랐어요'"]
        T2["'빠른 배달 감사'"]
        T3["'색상이 예뻐요'"]
    end

    subgraph EMBED["임베딩 모델"]
        direction TB
        E1["문맥 학습"]
        E2["벡터 변환"]
        E1 --> E2
    end

    subgraph SPACE["벡터 공간"]
        direction TB
        V1["[0.8, 0.2, ...]"]
        V2["[0.7, 0.3, ...]"]
        V3["[-0.1, 0.9, ...]"]

        SIM["유사 의미 → 가까운 거리"]
    end

    T1 --> EMBED
    T2 --> EMBED
    T3 --> EMBED
    EMBED --> V1
    EMBED --> V2
    EMBED --> V3

    style INPUT fill:#e3f2fd,stroke:#1976d2
    style EMBED fill:#fff3e0,stroke:#f57c00
    style SPACE fill:#e8f5e9,stroke:#388e3c
    style SIM fill:#c8e6c9,stroke:#388e3c
